{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/api/seedance-start",
      "dest": "/api/seedance-start-priced"
    },
    {
      "src": "/api/storyboard",
      "dest": "/api/seedance-status?_r=sb"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-annual-credit-grant",
      "schedule": "15 0 * * *"
    }
  ]
}
